{
  "name": "keeplin-srv",
  "version": "1.0.0",
  "description": "Servidor multiusuario con edición colaborativa en tiempo real para Keeplin",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "tsx --test src/index.test.ts",
    "test:watch": "tsx --test --watch src/index.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsunyermias/keeplin-srv.git"
  },
  "keywords": [
    "collaborative",
    "websocket",
    "yjs",
    "real-time"
  ],
  "author": "jsunyermias",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jsunyermias/keeplin-srv/issues"
  },
  "homepage": "https://github.com/jsunyermias/keeplin-srv#readme",
  "dependencies": {
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "jose": "5.2.0",
    "lib0": "0.2.91",
    "uuid": "9.0.1",
    "ws": "8.16.0",
    "y-protocols": "^1.0.6",
    "yjs": "13.6.11"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "18.19.0",
    "@types/uuid": "9.0.8",
    "@types/ws": "8.5.10",
    "tsx": "4.7.0",
    "typescript": "5.3.3"
  }
