PORT=3000
DATABASE_URL=postgres://keeplin:keeplin@localhost:5432/keeplin
# REQUIRED: the server refuses to start without a strong secret (>=16 chars, not this
# placeholder). Generate one with: openssl rand -hex 32
JWT_SECRET=
TOKEN_TTL_DAYS=365
CHANGES_RETENTION_DAYS=0
LINES_GC_DAYS=30
# Reclaim blob bytes of resources soft-deleted more than N days ago (0 = keep forever)
RESOURCE_PURGE_DAYS=0
# Operability
DB_MAX_CONNECTIONS=10
DB_ACQUIRE_TIMEOUT_SECS=10
DB_IDLE_TIMEOUT_SECS=600
DB_MAX_LIFETIME_SECS=1800
RATE_LIMIT_PER_MIN=0
SHUTDOWN_GRACE_SECS=20
LOG_JSON=false
# Max bytes for a resource binary upload (PUT /api/resources/:id/data); 413 over it
MAX_UPLOAD_BYTES=104857600
# Per-user quotas (0 = unlimited); 507 when exceeded
MAX_USER_STORAGE_BYTES=0
MAX_NOTES_PER_USER=0
# Set to false on a private/single-tenant deployment to close open signups
REGISTRATION_ENABLED=true
# History visibility for shared entities: 'creation' (all collaborators see full history) or
# 'access' (a collaborator sees only versions since they were granted access)
HISTORY_VISIBILITY=creation
RUST_LOG=info
